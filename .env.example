# Environment (development | production)
NODE_ENV=development

# Telegram Bot
# Get from @BotFather
TELEGRAM_BOT_TOKEN=

# Bot owner Telegram ID (REQUIRED)
# This user will have full access and cannot be removed
# Get your ID from @userinfobot
OWNER_TELEGRAM_ID=

# Master encryption key for private key storage (REQUIRED)
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this key safe! Losing it means losing access to all encrypted wallets.
# IMPORTANT: Do not change this key after users have created wallets.
MASTER_ENCRYPTION_KEY=

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Path to SQLite database
DATABASE_PATH=./data/bot.db

# Path to authorization database
AUTH_DATABASE_PATH=./data/auth.db

# HTTP server configuration (REQUIRED)
# Used for health checks, one-time secret links, and webhooks
HTTP_PORT=8000
HTTP_HOST=127.0.0.1

# Public URL for one-time secret links (REQUIRED)
# Must be accessible from the internet (e.g., https://your-app.koyeb.app)
# Seed phrases and private keys will be shown at: PUBLIC_URL/secret/{token}
PUBLIC_URL=

# Bot transport mode (polling | webhook)
# - polling: Long polling (default, suitable for local development)
# - webhook: Webhook mode (recommended for production, enables seamless redeploys)
BOT_TRANSPORT=polling

# Webhook URL (required when BOT_TRANSPORT=webhook)
# Full public HTTPS URL where Telegram will send updates
# Example: https://your-app.koyeb.app/webhook
# WEBHOOK_URL=

# Webhook secret token (optional, recommended for security)
# Used to validate that requests come from Telegram
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=

# Jupiter API key (REQUIRED)
# Get free Basic plan from https://portal.jup.ag/
JUPITER_API_KEY=

# Rate limiting
# Window size in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window (default: 30)
RATE_LIMIT_MAX_REQUESTS=30

# Market monitor
# Price polling interval in ms (default: 300000 = 5 minutes)
MARKET_POLL_INTERVAL_MS=300000
# Historical backfill source on cold start (binance | off)
MARKET_BACKFILL=binance
# UTC hour (0-23) after which the daily market digest is sent
MARKET_DIGEST_HOUR_UTC=9
